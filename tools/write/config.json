{
    "type": "function",
    "function": {
        "name": "write",
        "description": "写入或追加内容到文件。",
        "parameters": {
            "type": "object",
            "properties": {
                "path": {
                    "type": "string",
                    "description": "文件的完整路径。"
                },
                "content": {
                    "type": "string",
                    "description": "要写入的内容。"
                },
                "mode": {
                    "type": "string",
                    "enum": [
                        "overwrite",
                        "append"
                    ],
                    "description": "写入模式：'overwrite' 覆盖，'append' 追加。默认为 'overwrite'。"
                }
            },
            "required": [
                "path",
                "content"
            ]
        }
    }
}